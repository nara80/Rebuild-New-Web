<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f0f7ff"/>
      <stop offset="100%" style="stop-color:#dbeafe"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bg)"/>
  <rect x="80" y="100" width="640" height="400" rx="20" fill="#fff" stroke="#2c96f4" stroke-width="3"/>
  <rect x="120" y="140" width="560" height="320" rx="12" fill="#e8f4fd" stroke="#2c96f4" stroke-width="2"/>
  <text x="400" y="280" font-family="Quicksand,sans-serif" font-size="28" font-weight="700" fill="#2c96f4" text-anchor="middle">Mattress Protector Deep Pocket</text>
  <text x="400" y="320" font-family="Quicksand,sans-serif" font-size="16" fill="#666" text-anchor="middle">MildMate Custom Bedding</text>
</svg>
