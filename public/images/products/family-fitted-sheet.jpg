<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f0f7ff"/>
      <stop offset="100%" style="stop-color:#dbeafe"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bg)"/>
  <rect x="100" y="150" width="600" height="300" rx="16" fill="#fff" stroke="#2c96f4" stroke-width="3"/>
  <line x1="100" y1="200" x2="700" y2="200" stroke="#2c96f4" stroke-width="2" stroke-dasharray="8,4"/>
  <line x1="100" y1="400" x2="700" y2="400" stroke="#2c96f4" stroke-width="2" stroke-dasharray="8,4"/>
  <text x="400" y="340" font-family="Quicksand,sans-serif" font-size="28" font-weight="700" fill="#2c96f4" text-anchor="middle">Family Fitted Sheet</text>
  <text x="400" y="380" font-family="Quicksand,sans-serif" font-size="16" fill="#666" text-anchor="middle">MildMate Custom Bedding</text>
</svg>
