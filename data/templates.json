  "cardStyle": "    .product-card { background: #fff; border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; }\n    .product-card:hover { transform: translateY(-3px); box-shadow: 0 6px 24px rgba(0,0,0,0.12); }\n    .product-card .product-image { position: relative; overflow: hidden; background: var(--color-surface); }\n    .product-card .product-image img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; transition: transform 0.3s; }\n    .product-card:hover .product-image img { transform: scale(1.04); }\n    .product-card .product-info { padding: 20px; flex: 1; display: flex; flex-direction: column; }\n    .product-card .product-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }\n    .product-card .card-tag { font-size: 0.6875rem; font-weight: 600; color: var(--color-primary); background: #e8f4fd; padding: 3px 8px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.03em; }\n    .product-card .product-title { font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: 10px; line-height: 1.3; }\n    .product-card .product-price { font-size: 1.125rem; font-weight: 700; color: var(--color-primary); margin-bottom: 6px; }\n    .product-card .product-price-note { font-size: 0.75rem; color: #999; margin-bottom: 16px; }\n    .product-card .btn { display: block; text-align: center; text-decoration: none; padding: 12px; border-radius: var(--radius); font-weight: 600; font-size: 0.9375rem; transition: background 0.2s; }\n    .product-card .btn-primary { background: var(--color-primary); color: #fff; }\n    .product-card .btn-primary:hover { background: var(--color-primary-dark); }\n    @media (max-width: 480px) { .product-card .product-image img { aspect-ratio: 16/9; } }",
  "listingStyle": "    .listing-card { background: #fff; border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; transition: transform 0.2s ease, box-shadow 0.2s ease; display: flex; flex-direction: column; }\n    .listing-card:hover { transform: translateY(-3px); box-shadow: 0 6px 24px rgba(0,0,0,0.12); }\n    .listing-card .card-image { position: relative; overflow: hidden; background: var(--color-surface); }\n    .listing-card .card-image img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; transition: transform 0.3s; }\n    .listing-card:hover .card-image img { transform: scale(1.04); }\n    .listing-card .card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }\n    .listing-card .card-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }\n    .listing-card .card-tag { font-size: 0.6875rem; font-weight: 600; color: var(--color-primary); background: #e8f4fd; padding: 3px 8px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.03em; }\n    .listing-card .card-title { font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: 10px; line-height: 1.3; }\n    .listing-card .card-price { font-size: 1.125rem; font-weight: 700; color: var(--color-primary); margin-bottom: 6px; }\n    .listing-card .card-price-note { font-size: 0.75rem; color: #999; margin-bottom: 16px; }\n    .listing-card .card-cta { margin-top: auto; }\n    .listing-card .btn { display: block; text-align: center; text-decoration: none; padding: 12px; border-radius: var(--radius); font-weight: 600; font-size: 0.9375rem; transition: background 0.2s; }\n    .listing-card .btn-primary { background: var(--color-primary); color: #fff; }\n    .listing-card .btn-primary:hover { background: var(--color-primary-dark); }",
  "products_en": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"description\" content=\"Find your perfect fit at MildMate. Standard sizes for 8 regions, custom quotes for any shape. Bedding made to order in Thailand.\">\n  <title>Find Your Perfect Fit — MildMate</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Quicksand:wght@400;600;700&family=Sarabun:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"/css/main.css\">\n  <style>\n{{CARD_STYLE}}\n  </style>\n</head>\n<body>\n\n  <header class=\"site-header\">\n    <div class=\"container header-inner\">\n      <button class=\"hamburger\" aria-label=\"Open menu\" aria-expanded=\"false\"><span></span><span></span><span></span></button>\n      <a href=\"/\" class=\"logo-link\" aria-label=\"MildMate Home\"><img src=\"/images/logo.png\" alt=\"MildMate\" width=\"180\" height=\"50\"></a>\n      <nav class=\"main-nav\" aria-label=\"Main navigation\">\n        <ul class=\"nav-list\">\n          <li class=\"nav-item\"><a href=\"/\" class=\"nav-link\">Home</a></li>\n          <li class=\"nav-item\"><a href=\"/products/\" class=\"nav-link\">Shop</a></li>\n          <li class=\"nav-item\"><a href=\"/fabric/\" class=\"nav-link\">Fabrics</a></li>\n          <li class=\"nav-item\"><a href=\"/sizeguide/\" class=\"nav-link\">Size Guide</a></li>\n        </ul>\n      </nav>\n      <div class=\"header-actions\">\n        <button class=\"search-btn\" aria-label=\"Search products\" aria-expanded=\"false\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.3-4.3\"/></svg>\n        </button>\n        <a href=\"/account/\" class=\"account-btn\" aria-label=\"My account\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/></svg>\n        </a>\n        <a href=\"/checkout/\" class=\"cart-btn\" aria-label=\"Shopping cart\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"9\" cy=\"21\" r=\"1\"/><circle cx=\"20\" cy=\"21\" r=\"1\"/><path d=\"M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6\"/></svg>\n          <span class=\"cart-count\">0</span>\n        </a>\n        <div class=\"lang-toggle\" role=\"group\" aria-label=\"Language switch\">\n          <span data-lang=\"en\" class=\"active\">EN</span><span>/</span><span data-lang=\"th\">TH</span>\n        </div>\n      </div>\n    </div>\n    <div class=\"mobile-overlay\" aria-hidden=\"true\"></div>\n    <div class=\"mobile-drawer\" aria-label=\"Mobile menu\">\n      <div class=\"mobile-drawer-search\">\n        <form action=\"/products/\" method=\"get\" class=\"drawer-search-form\">\n          <input type=\"search\" name=\"q\" placeholder=\"Search bedding, fabrics, sizes...\" aria-label=\"Search products\" autocomplete=\"off\">\n          <button type=\"submit\" aria-label=\"Submit search\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.3-4.3\"/></svg>\n          </button>\n        </form>\n      </div>\n      <ul class=\"mobile-nav-list\">\n        <li><a href=\"/\">Home</a></li>\n        <li><a href=\"/products/\">Shop</a></li>\n        <li><a href=\"/fabric/\">Fabrics</a></li>\n        <li><a href=\"/sizeguide/\">Size Guide</a></li>\n      </ul>\n    </div>\n    <div class=\"search-overlay\" aria-hidden=\"true\">\n      <div class=\"search-overlay-inner\">\n        <button class=\"search-close\" aria-label=\"Close search\">\n          <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M18 6 6 18\"/><path d=\"m6 6 12 12\"/></svg>\n        </button>\n        <form action=\"/products/\" method=\"get\" class=\"search-form\">\n          <input type=\"search\" name=\"q\" placeholder=\"Search bedding, fabrics, sizes...\" aria-label=\"Search\" autocomplete=\"off\">\n          <button type=\"submit\" aria-label=\"Submit search\">\n            <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><path d=\"m21 21-4.3-4.3\"/></svg>\n          </button>\n        </form>\n      </div>\n    </div>\n  </header>\n\n  <main>\n    <section class=\"brand-hero\">\n      <div class=\"container\">\n        <h1>Find Your Perfect Fit</h1>\n        <p class=\"hero-sub\">Standard sizes for 8 regions. Custom quotes for any shape.</p>\n      </div>\n    </section>\n\n    <section class=\"section\">\n      <div class=\"container\">\n        <div class=\"filter-bar\" style=\"display:flex; flex-wrap:wrap; gap:16px; align-items:center; margin-bottom:32px; padding:16px; background:var(--color-surface); border-radius:var(--radius);\">\n          <div class=\"filter-group\">\n            <label for=\"filter-category\" style=\"font-weight:600; margin-right:8px;\">Category:</label>\n            <select id=\"filter-category\" class=\"filter-select\" style=\"padding:8px 12px; border:1px solid var(--color-border); border-radius:var(--radius); font-family:var(--font-main);\">\n              <optgroup label=\"Shop by Product\">\n              <option value=\"all\">All Products</option>\n              <option value=\"sheets\">Sheets</option>\n              <option value=\"duvet-covers\">Duvet Covers</option>\n              <option value=\"pillowcases\">Pillowcases</option>\n              <option value=\"protection\">Protection</option>\n              <option value=\"accessories\">Accessories</option>\n              </optgroup>\n              <optgroup label=\"Shop by Niche\">\n              <option value=\"marine\">Marine & Yacht</option>\n              <option value=\"family\">Family & Co-Sleep</option>\n              <option value=\"pets\">Pet Owner</option>\n              <option value=\"deep-pocket\">Deep Pocket</option>\n              <option value=\"boarding-dorm\">Boarding Dorm</option>\n              <option value=\"rv-truck\">RV & Truck Cab</option>\n              </optgroup>\n            </select>\n          </div>\n          <div class=\"filter-group\">\n            <label for=\"filter-fabric\" style=\"font-weight:600; margin-right:8px;\">Fabric:</label>\n            <select id=\"filter-fabric\" class=\"filter-select\" style=\"padding:8px 12px; border:1px solid var(--color-border); border-radius:var(--radius); font-family:var(--font-main);\">\n              <option value=\"all\">All</option>\n              <option value=\"breezeplus\">BreezePlus</option>\n              <option value=\"cloudsoft\">CloudSoft</option>\n              <option value=\"premacotton\">PremaCotton</option>\n              <option value=\"ecoluxe\">EcoLuxe</option>\n            </select>\n          </div>\n        </div>\n\n        <div class=\"product-grid\" style=\"grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:24px;\">\n{{PRODUCT_CARDS}}\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"site-footer\">\n    <div class=\"container\">\n      <div class=\"footer-grid\">\n        <div class=\"footer-col\">\n          <h3>Quick Links</h3>\n          <ul>\n            <li><a href=\"/about/\">About Us</a></li>\n            <li><a href=\"/contact/\">Contact Us</a></li>\n            <li><a href=\"/reviews/\">Reviews</a></li>\n          </ul>\n        </div>\n        <div class=\"footer-col\">\n          <h3>Customer Service</h3>\n          <ul>\n            <li><a href=\"/faq/\">FAQ</a></li>\n            <li><a href=\"/sizeguide/\">Size Guide</a></li>\n            <li><a href=\"/blogs/\">Blog</a></li>\n          </ul>\n        </div>\n        <div class=\"footer-col\">\n          <h3>Shop With Us</h3>\n          <div class=\"footer-icons-grid\">\n            <a href=\"https://www.etsy.com/shop/mildmate\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Etsy\" class=\"footer-icon-circle\"><img src=\"/images/Logo/Etsy.png\" alt=\"\"></a>\n            <a href=\"https://www.ebay.com/str/mildmate\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"eBay\" class=\"footer-icon-circle\"><img src=\"/images/Logo/eBay.png\" alt=\"\"></a>\n            <a href=\"https://shopee.co.th/neededshop_bt.2n.1y\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Shopee\" class=\"footer-icon-circle\"><img src=\"/images/Logo/Shopee.png\" alt=\"\"></a>\n            <a href=\"https://www.lazada.co.th/shop/needed-shop\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Lazada\" class=\"footer-icon-circle\"><img src=\"/images/Logo/Lazada.png\" alt=\"\"></a>\n          </div>\n        </div>\n        <div class=\"footer-col\">\n          <h3>Contact</h3>\n          <ul>\n            <li><a href=\"mailto:contact@mildmate.com\">contact@mildmate.com</a></li>\n            <li><a href=\"tel:+66872362364\">+66 (0)87 236 2364</a></li>\n          </ul>\n          <div class=\"footer-icons-grid contact-icons\">\n            <a href=\"https://wa.me/66811515995\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"WhatsApp\" class=\"footer-icon-circle\"><img src=\"/images/Logo/WhatsAPP.png\" alt=\"\"></a>\n            <a href=\"https://page.line.me/507abyoy\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"LINE\" class=\"footer-icon-circle\"><img src=\"/images/Logo/LineOA.png\" alt=\"\"></a>\n          </div>\n        </div>\n      </div>\n      <div class=\"footer-social-center\">\n        <a href=\"https://www.facebook.com/mildmate.bedsheets\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Facebook\" class=\"footer-social-icon\"><img src=\"/images/Logo/Facebook.png\" alt=\"\"></a>\n        <a href=\"https://www.instagram.com/mild_mate/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Instagram\" class=\"footer-social-icon\"><img src=\"/images/Logo/Instagram.png\" alt=\"\"></a>\n        <a href=\"https://www.tiktok.com/@bt.mildmate\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"TikTok\" class=\"footer-social-icon\"><img src=\"/images/Logo/TikTok.png\" alt=\"\"></a>\n        <a href=\"https://www.pinterest.com/mildmateshop/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"Pinterest\" class=\"footer-social-icon\"><img src=\"/images/Logo/Pinterest.png\" alt=\"\"></a>\n        <a href=\"https://www.youtube.com/channel/UCnxunfprych7pMss4zr6Qcw\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"YouTube\" class=\"footer-social-icon\"><img src=\"/images/Logo/YouTube.png\" alt=\"\"></a>\n      </div>\n      <div class=\"footer-bottom\">\n        <p>&copy; MildMate 2026</p>\n        <div class=\"footer-bottom-links\">\n          <a href=\"/policy/\">Privacy Policy</a>\n          <a href=\"/shipping/\">Returns &amp; Delivery</a>\n        </div>\n      </div>\n    </div>\n  </footer>\n\n  <script src=\"/js/nav.js\"></script>\n  <script src=\"/js/cart.js\"></script>\n  <script src=\"/js/cookie-consent.js\"></script>\n  <script>\n    // Product filter logic\n    const filterCategory = document.getElementById('filter-category');\n    const filterFabric = document.getElementById('filter-fabric');\n    const cards = document.querySelectorAll('.product-card');\n\n    function filterProducts() {\n      const cat = filterCategory.value;\n      const fabric = filterFabric.value;\n      cards.forEach(card => {\n        const cats = (card.dataset.categories || '').split(',');\n        const show = (cat === 'all' || cats.includes(cat));\n        card.style.display = show ? '' : 'none';\n      });\n    }\n\n    filterCategory.addEventListener('change', filterProducts);\n    filterFabric.addEventListener('change', filterProducts);\n  </script>\n</body>\n</html>",
